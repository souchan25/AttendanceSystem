    private async Task HandleImport(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            // Allow up to 10 MB for the Excel file
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var memoryStream = new System.IO.MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            if (!await JSRuntime.InvokeAsync<bool>("confirm", "This will COMPLETELY OVERWRITE current students, events, and records. PROCEED?")) return;

            var excelService = new AttendanceWeb.Services.ExcelImportExportService();
            var backupData = excelService.ImportDatabaseFromExcel(memoryStream);

            var json = System.Text.Json.JsonSerializer.Serialize(backupData);
            await Task.Run(() => Database.ImportDatabaseFromJson(json, AuthService.AdminId, AuthService.AdminUsername));

            await LoadData();
            await LoadActivityLogs();
            await JSRuntime.InvokeVoidAsync("alert", "Database imported successfully!");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Import failed: " + ex.Message);
        }
    }

    private async Task HandlePdfImport(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        pdfImportMessage = "";
        pdfImportSuccess = false;
        StateHasChanged();

        try
        {
            // Read PDF into memory (limit to 10MB)
            using var memoryStream = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var importedStudents = new List<Student>();
            int skippedCount = 0;

            using (var document = PdfDocument.Open(memoryStream))
            {
                foreach (var page in document.GetPages())
                {
                    var text = page.Text;
                    var lines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);

                    foreach (var line in lines)
                    {
                        var trimmed = line.Trim();
                        if (string.IsNullOrWhiteSpace(trimmed)) continue;

                        // Try to parse student ID pattern: YYYY-XXXX-L (e.g., 2024-0001-A)
                        var match = System.Text.RegularExpressions.Regex.Match(trimmed, @"(\d{4}-\d{4}-[A-Za-z])");
                        if (!match.Success) continue;

                        var studentId = match.Value.ToUpper();

                        // Check if student already exists
                        var existing = Database.GetStudentByStudentId(studentId);
                        if (existing != null)
                        {
                            skippedCount++;
                            continue;
                        }

                        // Extract remaining text after the student ID as the name
                        var afterId = trimmed.Substring(match.Index + match.Length).Trim();
                        // Also check text before the ID
                        var beforeId = trimmed.Substring(0, match.Index).Trim();

                        // Try to parse tab/comma-separated fields: StudentId, Name, Program, YearLevel, Section
                        var parts = System.Text.RegularExpressions.Regex.Split(trimmed, @"\t+|,\s*|\s{2,}");
                        // Remove empty entries
                        parts = parts.Where(p => !string.IsNullOrWhiteSpace(p)).ToArray();

                        string name = "";
                        string program = "";
                        int yearLevel = 1;
                        string section = "";

                        // Find the index of the student ID in parts
                        int idIdx = -1;
                        for (int i = 0; i < parts.Length; i++)
                        {
                            if (parts[i].Trim().Contains(studentId, StringComparison.OrdinalIgnoreCase))
                            {
                                idIdx = i;
                                break;
                            }
                        }

                        if (idIdx >= 0 && parts.Length > idIdx + 1)
                        {
                            // Fields after the student ID
                            var remaining = parts.Skip(idIdx + 1).ToArray();
                            if (remaining.Length >= 1) name = remaining[0].Trim();
                            if (remaining.Length >= 2) program = remaining[1].Trim();
                            if (remaining.Length >= 3 && int.TryParse(remaining[2].Trim(), out int yr)) yearLevel = yr;
                            if (remaining.Length >= 4) section = remaining[3].Trim();
                        }
                        else if (!string.IsNullOrEmpty(afterId))
                        {
                            name = afterId;
                        }
                        else if (!string.IsNullOrEmpty(beforeId))
                        {
                            name = beforeId;
                        }

                        if (string.IsNullOrWhiteSpace(name)) name = "Imported Student";

                        importedStudents.Add(new Student
                        {
                            StudentId = studentId,
                            Name = name,
                            Program = program,
                            YearLevel = yearLevel,
                            Section = section,
                            EnrolledDate = DateTime.Now,
                            IsActive = true,
                            IsVerified = false // Requires fingerprint enrollment
                        });
                    }
                }
            }

            if (importedStudents.Count == 0)
            {
                pdfImportMessage = $"No new students found in the PDF.{(skippedCount > 0 ? $" {skippedCount} already exist." : " Ensure the PDF contains student IDs in YYYY-XXXX-L format.")}";
                pdfImportSuccess = false;
                StateHasChanged();
                return;
            }

            if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Found {importedStudents.Count} new student(s) to import{(skippedCount > 0 ? $" ({skippedCount} skipped — already exist)" : "")}. They will be added as UNVERIFIED and need fingerprint enrollment. Proceed?"))
            {
                pdfImportMessage = "Import cancelled.";
                StateHasChanged();
                return;
            }

            int addedCount = 0;
            await Task.Run(() =>
            {
                foreach (var student in importedStudents)
                {
                    Database.AddStudent(student);
                    addedCount++;
                }
            });

            Database.LogActivity(AuthService.AdminId, AuthService.AdminUsername, "Import", "Students", $"Imported {addedCount} students from PDF file: {file.Name}");
            await LoadData();
            await LoadActivityLogs();
            pdfImportMessage = $"Successfully imported {addedCount} student(s).{(skippedCount > 0 ? $" {skippedCount} skipped (already exist)." : "")} Students need fingerprint enrollment to become verified.";
            pdfImportSuccess = true;
        }
        catch (Exception ex)
        {
            pdfImportMessage = "PDF import failed: " + ex.Message;
            pdfImportSuccess = false;
        }

        StateHasChanged();
    }

    // Settings - Password Change
    private void CancelPasswordChange()
    {
        showChangePassword = false;
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
        passwordChangeMessage = "";
    }

    private async Task SavePasswordChange()
    {
        passwordChangeMessage = "";
        passwordChangeSuccess = false;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            passwordChangeMessage = "Please fill in all fields.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordChangeMessage = "New passwords do not match.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(newPassword, @"^(?=.*[a-zA-Z])(?=.*\d)(?=.*[\W_]).{4,}$"))
        {
            passwordChangeMessage = "Password must contain letters, numbers, and special characters.";
            return;
        }

        try
        {
            var currentAdmin = await Task.Run(() => Database.GetAdminById(AuthService.AdminId));
            if (currentAdmin == null)
            {
                passwordChangeMessage = "Admin not found.";
                return;
            }

            if (currentAdmin.Password != currentPassword)
            {
                passwordChangeMessage = "Current password is incorrect.";
                return;
            }

            currentAdmin.Password = newPassword;
            await Task.Run(() => Database.UpdateAdmin(currentAdmin));

            passwordChangeMessage = "Password changed successfully!";
            passwordChangeSuccess = true;
            
            await Task.Delay(2000);
            CancelPasswordChange();
        }
        catch (Exception ex)
        {
            passwordChangeMessage = $"Error: {ex.Message}";
        }
    }


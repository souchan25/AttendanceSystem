    private async Task LoadData()
    {
        try
        {
            // Load all including deleted for archive support
            events = await Task.Run(() => Database.GetEvents(true));
            students = await Task.Run(() => Database.GetAllStudents());
            filteredStudents = students;
            sanctionRules = await Task.Run(() => Database.GetSanctionRules());
            
            // Auto-select first event if none selected
            if (selectedEventId == 0 && events.Count > 0)
            {
                selectedEventId = events[0].Id;
                await LoadEventRecords(selectedEventId);
            }

            // Count total templates
            totalTemplates = 0;
            foreach (var student in students)
            {
                var templates = await Task.Run(() => Database.GetStudentTemplates(student.Id));
                totalTemplates += templates.Count;
            }

            // Count total attendance records
            totalAttendance = 0;
            foreach (var evt in events)
            {
                var attendance = await Task.Run(() => Database.GetEventAttendance(evt.Id));
                totalAttendance += attendance.Count;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task LoadEventRecords(int eventId)
    {
        try 
        {
            selectedEventId = eventId;
            if (eventId == 0)
            {
                allEventRecords = await Task.Run(() => Database.GetAllAttendanceInfo());
            }
            else
            {
                allEventRecords = await Task.Run(() => Database.GetEventAttendance(eventId));
            }
            FilterEventRecords();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading records: {ex.Message}");
        }

    private async Task ProceedWithConfirmation()
    {
        showConfirmationModal = false;
        try
        {
            if (pendingDeleteEvent != null)
            {
                // Note: DeleteEvent in Database service handles IsDeleted = 1
                await Task.Run(() => Database.UpdateEvent(new Event { Id = pendingDeleteEvent.Id, IsDeleted = true, EventName = pendingDeleteEvent.EventName }));
                Database.LogActivity(AuthService.AdminId, AuthService.AdminUsername, "Delete", "Event", $"Soft-deleted event: {pendingDeleteEvent.EventName}");
                pendingDeleteEvent = null;
            }
            else if (pendingDeleteStudent != null)
            {
                await Task.Run(() => Database.DeleteStudent(pendingDeleteStudent.Id));
                Database.LogActivity(AuthService.AdminId, AuthService.AdminUsername, "Delete", "Student", $"Deleted student: {pendingDeleteStudent.Name}");
                pendingDeleteStudent = null;
            }
            else if (pendingDeleteAdmin != null)
            {
                var isSelfDelete = pendingDeleteAdmin.Id == AuthService.AdminId;
                var result = Database.DeleteAdminSecure(pendingDeleteAdmin.Id, AuthService.AdminId, AuthService.AdminUsername);
                if (!result.Success)
                {
                    await JSRuntime.InvokeVoidAsync("alert", result.Message);
                }
                else if (isSelfDelete)
                {
                    pendingDeleteAdmin = null;
                    await Logout();
                    return;
                }
                pendingDeleteAdmin = null;
                await LoadAdmins();
            }
            else if (pendingResetFilter == "Database")
            {
                Database.ResetDatabase(AuthService.AdminId, AuthService.AdminUsername);
                pendingResetFilter = null;
                await JSRuntime.InvokeVoidAsync("alert", "Database reset successful!");
            }

            await LoadData();
            await LoadActivityLogs();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Action failed: " + ex.Message);
        }
    }


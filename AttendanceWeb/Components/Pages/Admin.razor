                                                                        <button class="btn-icon danger" @onclick="() => DeleteSanctionRuleAction(rule.Id)" title="Delete">🗑️</button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                            else
                                            {
                                                <p style="color: var(--neutral-400); font-size: 0.875rem; font-style: italic; margin-left: 5px;">No rules defined for this semester.</p>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (settingsTab == "database")
                        {
                            <!-- Database Management Section -->
                            <div class="settings-card">
                                <h3>Database Management</h3>
                                <div class="db-actions-grid">
                                    <div class="db-action-card" style="flex-direction: column; align-items: flex-start; gap: 12px;">
                                        <div class="db-icon" style="background: var(--error-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🧹</div>
                                        <div class="db-info">
                                            <h4 style="margin: 0 0 8px 0;">Reset Records</h4>
                                            <p style="margin-bottom: 16px;">Clear all attendance, events, and students for the new school year. <strong>Admins are kept.</strong></p>
                                            <button class="btn btn-danger" @onclick="ConfirmResetDatabase" style="width: 100%;">Reset Database</button>
                                        </div>
                                    </div>
                                    <div class="db-action-card" style="flex-direction: column; align-items: flex-start; gap: 12px;">
                                        <div class="db-icon" style="background: var(--primary-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📥</div>
                                        <div class="db-info">
                                            <h4 style="margin: 0 0 8px 0;">Export Database</h4>
                                            <p style="margin-bottom: 16px;">Download a backup of the current database (Excel format).</p>
                                            <button class="btn btn-secondary" @onclick="ExportDatabase" style="width: 100%;">Export Excel</button>
                                        </div>
                                    </div>
                                    <div class="db-action-card" style="flex-direction: column; align-items: flex-start; gap: 12px;">
                                        <div class="db-icon" style="background: var(--success-50); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📤</div>
                                        <div class="db-info">
                                            <h4 style="margin: 0 0 8px 0;">Import Database</h4>
                                            <p style="margin-bottom: 16px;">Restore database from a previously exported Excel backup file.</p>

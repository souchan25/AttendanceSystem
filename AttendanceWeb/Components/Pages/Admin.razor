    private bool sortByEvent = false;

    private void ToggleSortByEvent()
    {
        sortByEvent = !sortByEvent;
        FilterEventRecords();
    }

    private string sortColumn = "Name";
    private bool sortAscending = true;

    private void ToggleSort(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        FilterEventRecords();
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column) return "↕";
        return sortAscending ? "↑" : "↓";
    }

    private void FilterEventRecords()
    {
        var query = allEventRecords.AsQueryable();

        if (selectedYearFilter != "All" && int.TryParse(selectedYearFilter, out int year))
        {
            query = query.Where(r => r.Student.YearLevel == year);
        }

        if (selectedSectionFilter != "All")
        {
            query = query.Where(r => r.Student.Section == selectedSectionFilter);
        }

        // Apply Sorting
        IOrderedQueryable<AttendanceInfo> orderedQuery;
        
        if (sortByEvent && selectedEventId == 0)
        {
            orderedQuery = query.OrderBy(r => r.Event.EventName);
        }
        else
        {
            switch (sortColumn)
            {
                case "StudentId":
                    orderedQuery = sortAscending ? query.OrderBy(r => r.Student.StudentId) : query.OrderByDescending(r => r.Student.StudentId);
                    break;
                case "YearLevel":
                    orderedQuery = sortAscending ? query.OrderBy(r => r.Student.YearLevel) : query.OrderByDescending(r => r.Student.YearLevel);
                    break;
                case "Section":
                    orderedQuery = sortAscending ? query.OrderBy(r => r.Student.Section) : query.OrderByDescending(r => r.Student.Section);
                    break;
                case "Name":
                default:
                    orderedQuery = sortAscending ? query.OrderBy(r => r.Student.Name) : query.OrderByDescending(r => r.Student.Name);
                    break;
            }
        }

        eventRecords = orderedQuery.ToList();
        StateHasChanged();
    }


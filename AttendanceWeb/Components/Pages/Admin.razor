                </div>

                <div class="settings-container">
                    <div class="settings-subtabs">
                        <button class="settings-pill @(settingsTab == "profile" ? "active" : "")" @onclick='() => settingsTab = "profile"'>
                            <span class="pill-icon">👤</span>
                            <span class="pill-label">My Profile</span>
                        </button>
                        <button class="settings-pill @(settingsTab == "accounts" ? "active" : "")" @onclick='() => settingsTab = "accounts"'>
                            <span class="pill-icon">🛡️</span>
                            <span class="pill-label">Accounts</span>
                        </button>
                        <button class="settings-pill @(settingsTab == "logs" ? "active" : "")" @onclick='() => settingsTab = "logs"'>
                            <span class="pill-icon">📜</span>
                            <span class="pill-label">Activity Logs</span>
                        </button>
                        <button class="settings-pill @(settingsTab == "sanctions" ? "active" : "")" @onclick='() => settingsTab = "sanctions"'>
                            <span class="pill-icon">⚖️</span>
                            <span class="pill-label">Sanctions</span>
                        </button>
                        <button class="settings-pill @(settingsTab == "database" ? "active" : "")" @onclick='() => settingsTab = "database"'>
                            <span class="pill-icon">💾</span>
                            <span class="pill-label">Database</span>
                        </button>
                        <button class="settings-pill @(settingsTab == "help" ? "active" : "")" @onclick='() => settingsTab = "help"'>
                            <span class="pill-icon">❓</span>
                            <span class="pill-label">Help</span>
                        </button>
                    </div>

                    <div class="settings-main">
                        @if (settingsTab == "profile")
                        {
                            <!-- My Profile Section -->
                            <div class="settings-card">
                                <h3>My Profile</h3>
                                @if (!showChangePassword)
                                {
                                    <div class="profile-info">
                                        <div class="profile-item" style="margin-bottom: 15px;">
                                            <label style="font-weight: 600; color: var(--neutral-500); display: block; font-size: 0.875rem;">Username</label>
                                            <span style="font-size: 1.1rem; color: var(--neutral-900);">@AuthService.AdminUsername</span>
                                        </div>
                                        <div class="profile-item" style="margin-bottom: 20px;">
                                            <label style="font-weight: 600; color: var(--neutral-500); display: block; font-size: 0.875rem;">Role</label>
                                            <span class="badge login" style="padding: 4px 12px; border-radius: 20px;">Administrator</span>
                                        </div>
                                        <button class="btn btn-primary" @onclick="() => showChangePassword = true">
                                            Change Password
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-card" style="margin: 0; background: white; border: none; padding: 0;">
                                        <h4>Change Password</h4>
                                        
                                        @if (!string.IsNullOrEmpty(passwordChangeMessage))
                                        {
                                            <div class="alert @(passwordChangeSuccess ? "alert-success" : "alert-error")">
                                                @passwordChangeMessage
                                            </div>
                                        }

                                        <div class="form-group">
                                            <label>Current Password *</label>
                                            <div class="password-wrapper">
                                                <input type="@(showCurrentPw ? "text" : "password")" @bind="currentPassword" class="form-control" />
                                                <button type="button" class="btn-toggle-pw" @onclick="() => showCurrentPw = !showCurrentPw" tabindex="-1">@(showCurrentPw ? "🙈" : "👁️")</button>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label>New Password *</label>
                                            <div class="password-wrapper">
                                                <input type="@(showNewPw ? "text" : "password")" @bind="newPassword" class="form-control" />
                                                <button type="button" class="btn-toggle-pw" @onclick="() => showNewPw = !showNewPw" tabindex="-1">@(showNewPw ? "🙈" : "👁️")</button>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label>Confirm New Password *</label>
                                            <div class="password-wrapper">
                                                <input type="@(showConfirmPw ? "text" : "password")" @bind="confirmPassword" class="form-control" />
                                                <button type="button" class="btn-toggle-pw" @onclick="() => showConfirmPw = !showConfirmPw" tabindex="-1">@(showConfirmPw ? "🙈" : "👁️")</button>
                                            </div>
                                        </div>

                                        <div class="form-actions" style="margin-top: 20px; border-top: 1px solid var(--neutral-100); padding-top: 20px;">
                                            <button class="btn btn-cancel" @onclick="CancelPasswordChange">Cancel</button>
                                            <button class="btn btn-primary" @onclick="SavePasswordChange">Update Password</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (settingsTab == "accounts")
                        {
                            <!-- Admin Management Section -->
                            <div class="settings-card">
                                <div class="section-header" style="margin-bottom: 24px;">
                                    <h3>Admin Accounts</h3>
                                    <button class="btn btn-primary btn-sm" @onclick="ShowAddAdminForm">+ Add Admin</button>
                                </div>

                                @if (showAddAdminForm)
                                {
                                    <div class="form-card" style="background: var(--neutral-50); margin-bottom: 24px; border: 1px solid var(--neutral-200);">
                                        <h4>@(editingAdminId == 0 ? "Add New Admin" : "Edit Admin")</h4>
                                        
                                        @if (!string.IsNullOrEmpty(adminFormMessage))
                                        {
                                            <div class="alert @(adminFormSuccess ? "alert-success" : "alert-error")">
                                                @adminFormMessage
                                            </div>
                                        }

                                        <div class="form-group">
                                            <label>Username *</label>
                                            <input type="text" @bind="adminForm.Username" class="form-control" placeholder="Enter username" />
                                        </div>

                                        <div class="form-group">
                                            <label>Name</label>
                                            <input type="text" @bind="adminForm.Name" class="form-control" placeholder="Full name (optional)" />
                                        </div>

                                        <div class="form-group">
                                            <label>Password *</label>
                                            <div class="password-wrapper">
                                                <input type="@(showAdminPw ? "text" : "password")" @bind="adminForm.Password" class="form-control" placeholder="Enter password" />
                                                <button type="button" class="btn-toggle-pw" @onclick="() => showAdminPw = !showAdminPw" tabindex="-1">@(showAdminPw ? "🙈" : "👁️")</button>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label>Security Question *</label>
                                            <select @bind="adminForm.SecurityQuestion" class="form-control">
                                                <option value="">Select a security question</option>
                                                <option value="What is the name of your first pet?">What is the name of your first pet?</option>
                                                <option value="What is your mother's maiden name?">What is your mother's maiden name?</option>
                                                <option value="What city were you born in?">What city were you born in?</option>
                                                <option value="What is your favorite food?">What is your favorite food?</option>
                                                <option value="What was the name of your first school?">What was the name of your first school?</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label>Security Answer *</label>
                                            <input type="text" @bind="adminForm.SecurityAnswer" class="form-control" placeholder="Enter your answer" />
                                        </div>

                                        <div class="form-actions">
                                            <button class="btn btn-cancel" @onclick="CancelAdminForm">Cancel</button>
                                            <button class="btn btn-primary" @onclick="SaveAdmin">
                                                @(editingAdminId == 0 ? "Create Admin" : "Update Admin")
                                            </button>
                                        </div>
                                    </div>
                                }

                                <div class="admins-list" style="display: flex; flex-direction: column; gap: 12px;">
                                    @foreach (var admin in adminsList)
                                    {
                                        <div class="admin-card" style="background: white; border: 1px solid var(--neutral-200); border-radius: 12px; padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                                            <div class="admin-info">
                                                <h4 style="margin: 0; font-size: 1rem; display: flex; align-items: center; gap: 8px;">
                                                    @admin.Username 
                                                    @if (admin.Id == AuthService.AdminId) { <span class="badge login" style="font-size: 0.65rem; padding: 2px 6px;">YOU</span> }
                                                </h4>
                                                @if (!string.IsNullOrEmpty(admin.Name))
                                                {
                                                    <p style="margin: 4px 0 0 0; font-size: 0.875rem; color: var(--neutral-500);">@admin.Name</p>
                                                }
                                                <div class="admin-meta-row" style="margin-top: 8px; font-size: 0.75rem; color: var(--neutral-400); display: flex; gap: 12px;">
                                                    <span>Created: @admin.CreatedDate.ToString("MMM dd, yyyy")</span>
                                                    @if (admin.LastLogin.HasValue) {
                                                        <span style="color: var(--primary-600); font-weight: 500;">Active: @admin.LastLogin.Value.ToString("MMM dd, HH:mm")</span>
                                                    }
                                                </div>
                                            </div>
                                            <div class="admin-actions">
                                                @if (admin.Id == AuthService.AdminId)
                                                {
                                                    <button class="btn-icon danger" @onclick="() => ConfirmDeleteAdmin(admin)" title="Delete your account">
                                                        🗑️
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn-icon disabled" disabled title="Only the owner can delete this account">
                                                        🗑️
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (settingsTab == "logs")
                        {
                            <!-- Activity Logs Section -->
                            <div class="settings-card">
                                <h3>Activity Logs</h3>
                                <div class="records-table-container" style="max-height: 600px; overflow-y: auto; border: 1px solid var(--neutral-200); border-radius: 12px;">
                                    <table class="records-table">
                                        <thead>
                                            <tr>
                                                <th>Admin</th>
                                                <th>Action</th>
                                                <th>Target</th>
                                                <th>Details</th>
                                                <th>Timestamp</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var log in activityLogs.OrderByDescending(l => l.Timestamp))
                                            {
                                                <tr>
                                                    <td><strong>@log.AdminUsername</strong></td>
                                                    <td><span class="badge @log.Action.ToLower()" style="font-size: 0.7rem; padding: 2px 8px;">@log.Action</span></td>
                                                    <td>@log.Target</td>
                                                    <td style="font-size: 0.8rem; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@log.Details">@log.Details</td>
                                                    <td style="white-space: nowrap; font-size: 0.8rem; color: var(--neutral-500);">@log.Timestamp.ToString("MMM dd, HH:mm:ss")</td>
                                                </tr>
                                            }
                                            @if (!activityLogs.Any())
                                            {
                                                <tr><td colspan="5" style="text-align: center; padding: 40px; color: var(--neutral-400);">No activity logs found.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }

                        @if (settingsTab == "sanctions")
                        {
                            <!-- Sanctions Settings Section -->
                            <div class="settings-card">
                                <div class="section-header" style="margin-bottom: 24px;">
                                    <h3>Sanction Rules</h3>
                                    <button class="btn btn-primary btn-sm" @onclick="ShowAddSanctionForm">+ Add Rule</button>
                                </div>

                                @if (showSanctionForm)
                                {
                                    <div class="form-card" style="background: var(--neutral-50); margin-bottom: 24px; border: 1px solid var(--neutral-200);">
                                        <h4>@(editingSanctionId == 0 ? "Add New Rule" : "Edit Rule")</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label>Semester *</label>
                                                <select @bind="sanctionForm.Semester" class="form-control">
                                                    <option value="First">First Semester</option>
                                                    <option value="Second">Second Semester</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label>Absence Count *</label>
                                                <input type="number" @bind="sanctionForm.AbsenceCount" class="form-control" min="0" />
                                            </div>
                                            <div class="form-group">
                                                <label style="display: flex; align-items: center; gap: 8px; margin-top: 32px; font-size: 0.875rem;">
                                                    <input type="checkbox" @bind="sanctionForm.IsOrMore" /> Or more
                                                </label>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label>Sanction Description *</label>
                                            <input type="text" @bind="sanctionForm.SanctionDescription" class="form-control" placeholder="e.g. 2 sako, 1 trapo" />
                                        </div>
                                        <div class="form-actions">
                                            <button class="btn btn-cancel" @onclick="CancelSanctionForm">Cancel</button>
                                            <button class="btn btn-primary" @onclick="SaveSanctionRule">
                                                @(editingSanctionId == 0 ? "Add Rule" : "Update Rule")
                                            </button>
                                        </div>
                                    </div>
                                }

                                <div class="sanctions-list" style="display: flex; flex-direction: column; gap: 24px;">
                                    @foreach (var semester in new[] { "First", "Second" })
                                    {
                                        var semRules = sanctionRules.Where(r => r.Semester == semester).OrderBy(r => r.AbsenceCount).ToList();
                                        <div class="semester-section">
                                            <h4 style="margin-bottom: 15px; color: var(--primary-700); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700;">@semester Semester</h4>

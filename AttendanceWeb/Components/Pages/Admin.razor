@page "/admin"
@page "/admin/dashboard"
@using AttendanceWeb.Models
@using AttendanceWeb.Services
@using Microsoft.AspNetCore.Components.Forms
@using UglyToad.PdfPig
@using UglyToad.PdfPig.Content
@inject AttendanceDatabase Database
@inject FingerprintApiClient ApiClient
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Admin Dashboard</PageTitle>

@if (!AuthService.IsAdminAuthenticated)
{
    <div class="unauthorized-container">
        <div class="unauthorized-card">
            <div class="unauthorized-icon">🔒</div>
            <h2>Access Denied</h2>
            <p>You need to be logged in as an admin to access this page.</p>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/admin/login")'>
                Go to Admin Login
            </button>
        </div>
    </div>
}
else
{
    <div class="page-container">
        <div class="content-card">
            <div class="page-header">
                <div>
                <h1 style="display: flex; align-items: center; gap: 12px;">
                    <img src="images/logo.png" alt="Logo" style="height: 40px; width: auto;" />
                    INFOTECH Admin Dashboard
                </h1>
                    <p>Welcome, @AuthService.AdminUsername</p>
                </div>
                <div style="display: flex; gap: var(--space-3); align-items: center;">
                    <button class="btn-fullscreen-admin" @onclick="ToggleFullscreen" title="@(isFullscreen ? "Exit Fullscreen" : "Enter Fullscreen")">
                        @(isFullscreen ? "🗗" : "⛶")
                    </button>
                    <button class="btn btn-secondary" @onclick="Logout">Logout</button>
                </div>
            </div>

        <!-- Tab Navigation -->
        <div class="tabs">
            <button class="tab @(activeTab == "events" ? "active" : "")" @onclick='() => activeTab = "events"'>
                📅 Events
            </button>
            <button class="tab @(activeTab == "students" ? "active" : "")" @onclick='() => activeTab = "students"'>
                👥 Students
            </button>
            @* Records tab hidden for now. Records are opened directly from Events via "View Records" action.
            <button class="tab @(activeTab == "records" ? "active" : "")" @onclick='() => activeTab = "records"'>
                📋 Records
            </button>
            *@
            <button class="tab @(activeTab == "stats" ? "active" : "")" @onclick='() => activeTab = "stats"'>
                📊 Statistics
            </button>
            <button class="tab @(activeTab == "settings" ? "active" : "")" @onclick='() => activeTab = "settings"'>
                ⚙️ Settings
            </button>
        </div>

        <!-- Events Tab -->
        @if (activeTab == "events")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Event Management</h2>
                    <button class="btn btn-primary" @onclick="ShowNewEventForm">+ Create Event</button>
                </div>

                @if (showEventForm)
                {
                    <div class="form-card">
                        <h3>New Event</h3>
                        <div class="form-group">
                            <label>Event Name *</label>
                            <input type="text" @bind="eventForm.EventName" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label>Description</label>
                            <textarea @bind="eventForm.Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Semester *</label>
                                <select @bind="eventForm.Semester" class="form-control">
                                    <option value="First">First Semester</option>
                                    <option value="Second">Second Semester</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Period *</label>
                                <select @bind="eventForm.Period" class="form-control">
                                    <option value="Midterm">Midterm</option>
                                    <option value="Final">Final</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Academic Year *</label>
                                <input type="text" @bind="eventForm.AcademicYear" 
                                       placeholder="2024-2025" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label>Event Date *</label>
                                <input type="date" @bind="eventForm.EventDate" class="form-control" />
                            </div>
                        </div>


                        <div class="form-row">
                             <div class="form-group">
                                <label>Time In (Start)</label>
                                <input type="time" @bind="eventForm.TimeInStart" class="form-control" 
                                       />
                             </div>
                             <div class="form-group">
                                <label>Time In (End)</label>
                                <input type="time" @bind="eventForm.TimeInEnd" class="form-control" 
                                       disabled="@(eventForm.TimeInStart == null)"
                                       min="@(eventForm.TimeInStart?.ToString("HH:mm"))" />
                             </div>
                        </div>

                        <div class="form-row">
                             <div class="form-group">
                                <label>Time Out (Start)</label>
                                <input type="time" @bind="eventForm.TimeOutStart" class="form-control" 
                                       />
                             </div>
                             <div class="form-group">
                                <label>Time Out (End)</label>
                                <input type="time" @bind="eventForm.TimeOutEnd" class="form-control" 
                                       disabled="@(eventForm.TimeOutStart == null)"
                                       min="@(eventForm.TimeOutStart?.ToString("HH:mm"))" />
                             </div>
                        </div>

                        <div class="form-actions">
                            <button class="btn btn-cancel" @onclick="CancelEventForm">Cancel</button>
                            <button class="btn btn-primary" @onclick="SaveEvent">
                                Create Event
                            </button>
                        </div>
                    </div>
                }


                <div class="filter-controls" style="margin-bottom: 20px;">
                    <button class="btn btn-sm @(eventFilter == "Ongoing" ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => eventFilter = "Ongoing"'>Ongoing</button>
                    <button class="btn btn-sm @(eventFilter == "Completed" ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => eventFilter = "Completed"'>Completed</button>
                    <button class="btn btn-sm @(eventFilter == "Upcoming" ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => eventFilter = "Upcoming"'>Upcoming</button>
                    <button class="btn btn-sm @(eventFilter == "Archived" ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => eventFilter = "Archived"'>Archived</button>
                </div>

                <div class="events-list">
                    @foreach (var evt in events.Where(e => {
                        if (eventFilter == "Archived") return e.IsDeleted;
                        if (e.IsDeleted) return false;
                        if (eventFilter == "Ongoing") return e.IsActive;
                        if (eventFilter == "Completed") return !e.IsActive && e.EventDate < DateTime.Now;
                        if (eventFilter == "Upcoming") return !e.IsActive && e.EventDate >= DateTime.Now;
                        return true;
                    }).OrderByDescending(e => e.EventDate))
                    {
                        <div class="event-card @(evt.IsDeleted ? "archived" : "")">
                            <div class="event-header">
                                <div class="event-info">
                                    <h4>@evt.EventName 
                                        @if(!evt.IsDeleted) {
                                            <span class="status-badge-pill @(evt.IsActive ? "ongoing" : "completed")">
                                                @(evt.IsActive ? "Ongoing" : "Completed")
                                            </span>
                                        }
                                    </h4>
                                    <p class="event-date">📅 @evt.EventDate.ToString("MMMM dd, yyyy") (@evt.AcademicYear)</p>
                                    
                                    <div class="event-schedule-admin">
                                        <div class="schedule-row">
                                            <span class="schedule-label">⬇ Time In:</span>
                                            <span class="schedule-value">
                                                @(evt.TimeInStart?.ToString("hh:mm tt") ?? "--") - @(evt.TimeInEnd?.ToString("hh:mm tt") ?? "--")
                                            </span>
                                        </div>
                                        <div class="schedule-row">
                                            <span class="schedule-label">⬆ Time Out:</span>
                                            <span class="schedule-value">
                                                @(evt.TimeOutStart?.ToString("hh:mm tt") ?? "--") - @(evt.TimeOutEnd?.ToString("hh:mm tt") ?? "--")
                                            </span>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <p class="event-desc">@evt.Description</p>
                                    }
                                </div>
                                <div class="event-actions">
                                    @if (!evt.IsDeleted)
                                    {
                                        <button class="btn-icon" @onclick="() => ViewEventRecords(evt)" title="View Records">📋</button>
                                        <button class="btn-icon" @onclick="() => ToggleEventStatus(evt)" 
                                                title="@(evt.IsActive ? "Mark Completed" : "Mark Ongoing")">
                                            @(evt.IsActive ? "✅" : "🏁")
                                        </button>
                                        
                                        @if (evt.IsActive)
                                        {
                                            <button class="btn-icon disabled" disabled title="Cannot delete ongoing event">🗑️</button>
                                        }
                                        else if (evt.EventDate >= DateTime.Today)
                                        {
                                            <button class="btn-icon disabled" disabled title="Only past events can be deleted">🗑️</button>
                                        }
                                        else
                                        {
                                            <button class="btn-icon danger" @onclick="() => ConfirmDeleteEvent(evt)" title="Delete">🗑️</button>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">Archived</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }


        <!-- Students Tab -->
        @if (activeTab == "students")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Student Management</h2>
                    <div class="header-actions">
                        <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/enroll")'>+ Add Student</button>
                        <div class="form-group" style="margin: 0; width: 150px;">
                            <select @bind="studentYearFilter" @bind:after="FilterStudents" class="form-control">
                                <option value="All">All Years</option>
                                <option value="1">1st Year</option>
                                <option value="2">2nd Year</option>
                                <option value="3">3rd Year</option>
                                <option value="4">4th Year</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin: 0; width: 150px;">
                            <select @bind="studentSectionFilter" @bind:after="FilterStudents" class="form-control">
                                <option value="All">All Sections</option>
                                <option value="A">Section A</option>
                                <option value="B">Section B</option>
                                <option value="C">Section C</option>
                                <option value="D">Section D</option>
                                <option value="E">Section E</option>
                            </select>
                        </div>
                        <div class="search-box">
                            <input type="text" @bind="studentSearch" @bind:event="oninput" @bind:after="FilterStudents" 
                                   placeholder="Search students..." class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="students-grid">
                    @foreach (var student in filteredStudents)
                    {
                        <div class="student-card">
                            <div class="student-header">
                                <span class="student-badge-status @(student.IsActive ? "active" : "inactive")" 
                                      title="@(student.IsActive ? "Active" : "Inactive")"></span>
                                <span class="student-badge-status @(student.IsVerified ? "verified" : "unverified")" 
                                      title="@(student.IsVerified ? "Verified" : "Unverified")" style="margin-left: 5px;"></span>
                            </div>
                            <div class="student-avatar">@GetInitials(student.Name)</div>
                            <div class="student-info">
                                <h4>@student.Name</h4>
                                <span class="student-id">@student.StudentId</span>
                                <span class="student-detail">@student.Program - Y@(student.YearLevel) @(student.Section != null ? $"- Sec {student.Section}" : "")</span>
                                <span class="enrolled-date">Enrolled: @student.EnrolledDate.ToString("MMM dd, yyyy")</span>
                            </div>

                            <div class="student-actions">
                                <button class="btn-icon" @onclick="() => ShowStudentHistory(student)" title="View History">📜</button>
                                <button class="btn-icon" @onclick="() => StartRecapture(student)" title="Recapture Fingerprints">🔄</button>
                                <button class="btn-icon" @onclick="() => ToggleStudentStatus(student)" 
                                        title="@(student.IsActive ? "Deactivate" : "Activate")">
                                    @(student.IsActive ? "🔒" : "🔓")
                                </button>
                                <button class="btn-icon danger" @onclick="() => ConfirmDeleteStudent(student)" title="Delete">
                                    🗑️
                                </button>
                            </div>
                        </div>
                    }
                </div>


                @if (filteredStudents.Count == 0)
                {
                    <div class="no-data">
                        <div class="icon">🔍</div>
                        <p>No students found</p>
                    </div>
                }

                @if (showStudentHistoryModal && selectedStudentForHistory != null)
                {
                    <div class="modal-overlay">
                        <div class="modal-card">
                            <div class="modal-header">
                                <h3>History: @selectedStudentForHistory.Name</h3>
                                <button class="btn-close" @onclick="CloseStudentHistory">×</button>
                            </div>
                            <div class="modal-body">
                                <div class="stats-summary">
                                    <div class="stat-box present">
                                        <span class="value">@studentStats.Present</span>
                                        <span class="label">Present</span>
                                    </div>
                                    <div class="stat-box absent">
                                        <span class="value">@studentStats.Absent</span>
                                        <span class="label">Absent</span>
                                    </div>
                                    <div class="stat-box total">
                                        <span class="value">@(studentStats.Present + studentStats.Absent)</span>
                                        <span class="label">Total Events</span>
                                    </div>
                                </div>

                                <div class="history-table-container">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>Event</th>
                                                <th>Date</th>
                                                <th>Time In</th>
                                                <th>Time Out</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var record in studentHistory)
                                            {
                                                <tr>
                                                    <td>@record.Event.EventName</td>
                                                    <td>@record.Event.EventDate.ToString("MMM dd")</td>
                                                    <td>@(record.Record.TimeIn?.ToString("hh:mm tt") ?? "-")</td>
                                                    <td>@(record.Record.TimeOut?.ToString("hh:mm tt") ?? "-")</td>
                                                    <td>
                                                        <span class="status-badge @(record.Record.Status.ToLower())">
                                                            @record.Record.Status
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                @if (studentSanctions.Count > 0)
                                {
                                    <div style="margin-top: 20px;">
                                        <h4 style="margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                                            <span>⚠️</span> Sanctions
                                        </h4>
                                        <div style="display: flex; flex-direction: column; gap: 10px;">
                                            @foreach (var sanction in studentSanctions)
                                            {
                                                <div style="background: #fff7ed; border: 1px solid #fed7aa; border-radius: 12px; padding: 14px 18px;">
                                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                                                        <span style="font-weight: 700; color: #9a3412; font-size: 0.9rem;">@sanction.Semester Semester — @sanction.AcademicYear</span>
                                                        <span style="background: #ef4444; color: white; padding: 2px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700;">@sanction.AbsenceCount absence(s)</span>
                                                    </div>
                                                    <div style="color: #c2410c; font-weight: 600; font-size: 0.95rem;">📋 @sanction.SanctionDescription</div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (showRecaptureModal && recaptureStudent != null)
                {
                    <div class="modal-overlay">
                        <div class="modal-card" style="max-width: 700px;">
                            <div class="modal-header">
                                <h3>🔄 Recapture Fingerprints: @recaptureStudent.Name</h3>
                                <button class="btn-close" @onclick="CancelRecapture" disabled="@isRecapturing">×</button>
                            </div>
                            <div class="modal-body">
                                <div class="progress-section" style="text-align: center; margin-bottom: 20px;">
                                    <h4>Fingerprint Samples: @recaptureTemplates.Count / 5</h4>
                                    <div class="progress-bar" style="width: 100%; height: 12px; background: var(--neutral-200); border-radius: 9999px; overflow: hidden; margin-bottom: 8px;">
                                        <div style="height: 100%; width: @(recaptureTemplates.Count * 20)%; background: linear-gradient(90deg, var(--success-600), var(--success-500)); border-radius: 9999px; transition: width 0.5s;"></div>
                                    </div>
                                    <p style="color: var(--neutral-600); font-size: 0.875rem;">Please scan finger from 5 different angles for better accuracy</p>
                                </div>

                                <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-bottom: 20px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        int sampleNum = i;
                                        var template = recaptureTemplates.FirstOrDefault(t => t.SampleNumber == sampleNum);
                                        <div style="border: 2px solid @(template != null ? "var(--success-500)" : "var(--neutral-200)"); border-radius: 12px; padding: 12px; text-align: center; background: @(template != null ? "var(--success-50, #f0fdf4)" : "white");">
                                            <div style="font-weight: 600; font-size: 0.8rem; margin-bottom: 8px; display: flex; justify-content: space-between;">Sample @sampleNum @if(template != null){<span style="color: var(--success-600);">✓</span>}</div>
                                            @if (currentRecaptureSample == sampleNum && isRecapturing)
                                            {
                                                <div style="padding: 8px;"><div class="spinner" style="width: 24px; height: 24px; margin: 0 auto;"></div><p style="font-size: 0.75rem; margin: 4px 0 0 0;">Scanning...</p></div>
                                            }
                                            else if (template != null)
                                            {
                                                <div style="font-size: 0.75rem; color: var(--success-600); font-weight: 600;">Q: @template.Quality</div>
                                            }
                                            else
                                            {
                                                <button class="btn-capture-small" @onclick="() => RecaptureSample(sampleNum)" disabled="@(isRecapturing || recaptureTemplates.Count != sampleNum - 1)">
                                                    👆 Capture
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(recaptureMessage))
                                {
                                    <div class="alert @(recaptureMessage.Contains("✓") ? "alert-success" : "alert-error")">
                                        @recaptureMessage
                                    </div>
                                }

                                <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--neutral-200);">
                                    <button class="btn btn-cancel" @onclick="CancelRecapture" disabled="@isRecapturing">Cancel</button>
                                    <button class="btn btn-primary" @onclick="SaveRecapture" disabled="@(recaptureTemplates.Count < 5 || isSavingRecapture)">
                                        @(isSavingRecapture ? "Saving..." : "Save New Fingerprints ✓")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Records Tab -->
        @if (activeTab == "records")
        {
            <div class="tab-content">
                <div class="section-header">
                    <h2>Attendance Records</h2>
                    <div class="header-actions">
                        <button class="btn btn-outline-primary btn-sm" @onclick="ExportRecordsToExcel" style="display: flex; align-items: center; gap: 8px;">
                            📊 Export Excel
                        </button>
                        <button class="btn btn-outline-primary btn-sm" @onclick="ExportRecordsToPDF" style="display: flex; align-items: center; gap: 8px;">
                            📄 Export PDF
                        </button>
                    </div>
                </div>
                
                <div class="filter-bar" style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; align-items: flex-end;">
                    <div class="form-group" style="margin: 0; min-width: 300px;">
                        <label style="font-size: 0.75rem; font-weight: 600; color: var(--neutral-500); margin-bottom: 4px; display: block;">Select Event</label>
                        <select @bind="selectedEventId" @bind:after="() => LoadEventRecords(selectedEventId)" class="form-control">
                            <option value="0">All Events</option>
                            @{ var ongoingEvts = events.Where(e => !e.IsDeleted && e.IsActive).OrderByDescending(e => e.EventDate).ToList(); }
                            @{ var completedEvts = events.Where(e => !e.IsDeleted && !e.IsActive).OrderByDescending(e => e.EventDate).ToList(); }
                            @{ var archivedEvts = events.Where(e => e.IsDeleted).OrderByDescending(e => e.EventDate).ToList(); }
                            @if (ongoingEvts.Any())
                            {
                                <optgroup label="Ongoing">
                                    @foreach (var evt in ongoingEvts)
                                    {
                                        <option value="@evt.Id">@evt.EventName (@evt.Period - @evt.AcademicYear)</option>
                                    }
                                </optgroup>
                            }
                            @if (completedEvts.Any())
                            {
                                <optgroup label="Completed">
                                    @foreach (var evt in completedEvts)
                                    {
                                        <option value="@evt.Id">@evt.EventName (@evt.Period - @evt.AcademicYear)</option>
                                    }
                                </optgroup>
                            }
                            @if (archivedEvts.Any())
                            {
                                <optgroup label="Archived">
                                    @foreach (var evt in archivedEvts)
                                    {
                                        <option value="@evt.Id">@evt.EventName (@evt.Period - @evt.AcademicYear)</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="margin: 0; width: 140px;">
                        <label style="font-size: 0.75rem; font-weight: 600; color: var(--neutral-500); margin-bottom: 4px; display: block;">Year Level</label>
                        <select @bind="selectedYearFilter" @bind:after="FilterEventRecords" class="form-control">
                            <option value="All">All Years</option>
                            <option value="1">1st Year</option>
                            <option value="2">2nd Year</option>
                            <option value="3">3rd Year</option>
                            <option value="4">4th Year</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin: 0; width: 140px;">
                        <label style="font-size: 0.75rem; font-weight: 600; color: var(--neutral-500); margin-bottom: 4px; display: block;">Section</label>
                        <select @bind="selectedSectionFilter" @bind:after="FilterEventRecords" class="form-control">
                            <option value="All">All Sections</option>
                            <option value="A">Section A</option>
                            <option value="B">Section B</option>
                            <option value="C">Section C</option>
                            <option value="D">Section D</option>
                            <option value="E">Section E</option>
                        </select>
                    </div>
                </div>

                @if (eventRecords.Count > 0)
                {
                    <div class="records-table-container">
                        <table class="records-table">
                            <thead>
                                <tr>
                                    <th @onclick='() => ToggleSort("StudentId")' style="cursor: pointer">Student ID @GetSortIcon("StudentId")</th>
                                    <th @onclick='() => ToggleSort("Name")' style="cursor: pointer">Name @GetSortIcon("Name")</th>
                                    <th @onclick='() => ToggleSort("YearLevel")' style="cursor: pointer">Year @GetSortIcon("YearLevel")</th>
                                    <th @onclick='() => ToggleSort("Section")' style="cursor: pointer">Sec @GetSortIcon("Section")</th>
                                    @if (selectedEventId == 0)
                                    {
                                        <th @onclick="ToggleSortByEvent" style="cursor: pointer">Event ↕</th>
                                    }
                                    <th>Time In</th>
                                    <th>Time Out</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var record in eventRecords)
                                {
                                    var status = record.Record.TimeIn != null && record.Record.TimeOut != null ? "Complete" :
                                                 record.Record.TimeIn != null ? "Time In Only" : "No Record";
                                    var statusClass = status == "Complete" ? "status-complete" : 
                                                     status == "Time In Only" ? "status-partial" : "status-none";
                                    
                                    <tr>
                                        <td>@record.Student.StudentId</td>
                                        <td><strong>@record.Student.Name</strong></td>
                                        <td>@record.Student.YearLevel</td>
                                        <td>@(record.Student.Section ?? "-")</td>
                                        @if (selectedEventId == 0)
                                        {
                                            <td>@record.Event.EventName</td>
                                        }
                                        <td>@(record.Record.TimeIn?.ToString("hh:mm tt") ?? "-")</td>
                                        <td>@(record.Record.TimeOut?.ToString("hh:mm tt") ?? "-")</td>
                                        <td><span class="status-badge @statusClass">@status</span></td>
                                        <td>@record.Record.RecordDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <button class="btn-icon danger" @onclick="() => DeleteRecord(record.Record.Id)" title="Soft Delete">🗑️</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div style="margin-top: var(--space-4); color: var(--neutral-600); font-size: 0.875rem;">
                        <strong>@eventRecords.Count</strong> attendance record(s) found
                    </div>
                }
                else
                {
                    <div class="no-data">
                        <div class="icon">📋</div>
                        <p>No attendance records for this event</p>
                    </div>
                }
            </div>
        }

        <!-- Statistics Tab -->
        @if (activeTab == "stats")
        {
            <div class="tab-content">
                <h2>System Statistics</h2>

                <div class="stats-grid">
                    <div class="stat-card clickable" @onclick='() => activeTab = "students"'>
                        <div class="stat-icon">👥</div>
                        <div class="stat-content">
                            <div class="stat-value">@students.Count</div>
                            <div class="stat-label">Total Students</div>
                            <div class="stat-detail">@students.Count(s => s.IsActive) Active</div>
                        </div>
                    </div>

                    <div class="stat-card clickable" @onclick='() => activeTab = "events"'>
                        <div class="stat-icon">📅</div>
                        <div class="stat-content">
                            <div class="stat-value">@events.Count</div>
                            <div class="stat-label">Total Events</div>
                            <div class="stat-detail">@events.Count(e => e.IsActive) Active</div>
                        </div>
                    </div>

                    <div class="stat-card clickable" @onclick='() => activeTab = "students"'>
                        <div class="stat-icon">👆</div>
                        <div class="stat-content">
                            <div class="stat-value">@totalTemplates</div>
                            <div class="stat-label">Fingerprint Templates</div>
                            <div class="stat-detail">@(students.Count * 5) Expected</div>
                        </div>
                    </div>

                    <div class="stat-card clickable" @onclick='() => activeTab = "records"'>
                        <div class="stat-icon">✓</div>
                        <div class="stat-content">
                            <div class="stat-value">@totalAttendance</div>
                            <div class="stat-label">Total Attendance</div>
                            <div class="stat-detail">All Time</div>
                        </div>
                    </div>
                </div>

                <div class="recent-activity">
                    <h3>Recent Students</h3>
                    <div class="activity-list">
                        @foreach (var student in students.OrderByDescending(s => s.EnrolledDate).Take(5))
                        {
                            <div class="activity-item">
                                <div class="activity-icon">✨</div>
                                <div class="activity-content">
                                    <strong>@student.Name</strong> enrolled
                                    <span class="activity-time">@GetTimeAgo(student.EnrolledDate)</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Settings Tab -->
        @if (activeTab == "settings")
        {
            <div class="tab-content">
                <div class="section-header">

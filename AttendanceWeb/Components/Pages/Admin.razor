    // Fingerprint Recapture
    private bool showRecaptureModal = false;
    private Student? recaptureStudent = null;
    private List<FingerprintTemplate> recaptureTemplates = new();
    private bool isRecapturing = false;
    private bool isSavingRecapture = false;
    private int currentRecaptureSample = 0;
    private string recaptureMessage = "";

    private void StartRecapture(Student student)
    {
        recaptureStudent = student;
        recaptureTemplates.Clear();
        currentRecaptureSample = 0;
        recaptureMessage = "";
        showRecaptureModal = true;
    }

    private void CancelRecapture()
    {
        showRecaptureModal = false;
        recaptureStudent = null;
        recaptureTemplates.Clear();
        recaptureMessage = "";
    }

    private async Task RecaptureSample(int sampleNumber)
    {
        isRecapturing = true;
        currentRecaptureSample = sampleNumber;
        recaptureMessage = $"Capturing sample {sampleNumber}...";
        StateHasChanged();

        try
        {
            var response = await ApiClient.CaptureAsync();
            if (response.Success && !string.IsNullOrEmpty(response.Template))
            {
                recaptureTemplates.Add(new FingerprintTemplate
                {
                    SampleNumber = sampleNumber,
                    TemplateData = response.Template,
                    Quality = response.Quality,
                    CapturedDate = DateTime.Now
                });
                recaptureMessage = $"✓ Sample {sampleNumber} captured! Quality: {response.Quality}";
            }
            else
            {
                recaptureMessage = $"❌ Failed: {response.Message}";
            }
        }
        catch (Exception ex)
        {
            recaptureMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            isRecapturing = false;
            currentRecaptureSample = 0;
            StateHasChanged();
        }
    }

    private async Task SaveRecapture()
    {
        if (recaptureStudent == null || recaptureTemplates.Count < 5) return;

        isSavingRecapture = true;
        recaptureMessage = "Saving new fingerprints...";
        StateHasChanged();

        try
        {
            // Delete old templates
            await Task.Run(() => Database.DeleteStudentTemplates(recaptureStudent.Id));

            // Save new templates
            foreach (var template in recaptureTemplates)
            {
                template.StudentId = recaptureStudent.Id;
                await Task.Run(() => Database.AddFingerprintTemplate(template));
            }

            recaptureMessage = "✓ Fingerprints recaptured successfully!";
            StateHasChanged();
            await Task.Delay(1500);

            showRecaptureModal = false;
            recaptureStudent = null;
            recaptureTemplates.Clear();
            recaptureMessage = "";
            await LoadData();
        }
        catch (Exception ex)
        {
            recaptureMessage = $"❌ Error: {ex.Message}";
        }
        finally
        {
            isSavingRecapture = false;
            StateHasChanged();
        }
    }


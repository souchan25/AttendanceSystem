                                                <InputFile OnChange="HandleImport" id="db-import" style="display: none;" accept=".xlsx" />
                                                <label for="db-import" class="btn btn-primary" style="width: 100%; text-align: center; cursor: pointer; display: block; padding: 12px;">
                                                    Import Excel
                                                </label>
                                            </div>
                                            <button class="btn btn-secondary btn-sm" @onclick="() => ShowFormatVisualizer(true)" style="margin-top: 8px; width: 100%;">View Format</button>
                                        </div>
                                    </div>
                                    <div class="db-action-card" style="flex-direction: column; align-items: flex-start; gap: 12px;">
                                        <div class="db-icon" style="background: #fff3e0; width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📄</div>

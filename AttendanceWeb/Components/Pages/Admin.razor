                                                    Import PDF
                                                </label>
                                            </div>
                                            <button class="btn btn-secondary btn-sm" @onclick="() => ShowFormatVisualizer(false)" style="margin-top: 8px; width: 100%;">View Format</button>
                                            @if (!string.IsNullOrEmpty(pdfImportMessage))
                                            {
                                                <div class="alert @(pdfImportSuccess ? "alert-success" : "alert-error")" style="margin-top: 12px;">
                                                    @pdfImportMessage

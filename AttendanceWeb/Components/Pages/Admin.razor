    private void FilterStudents()
    {
        IEnumerable<Student> result = students;

        // Apply year level filter
        if (studentYearFilter != "All" && int.TryParse(studentYearFilter, out int yearVal))
        {
            result = result.Where(s => s.YearLevel == yearVal);
        }

        // Apply section filter
        if (studentSectionFilter != "All")
        {
            result = result.Where(s => s.Section != null && s.Section.Equals(studentSectionFilter, StringComparison.OrdinalIgnoreCase));
        }

        // Apply text search
        if (!string.IsNullOrWhiteSpace(studentSearch))
        {
            var query = studentSearch.ToLower();
            result = result.Where(s =>
                s.Name.ToLower().Contains(query) ||
                s.StudentId.ToLower().Contains(query) ||
                s.Program.ToLower().Contains(query) ||
                (s.Section != null && s.Section.ToLower().Contains(query))
            );
        }

        filteredStudents = result.ToList();
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[parts.Length - 1][0]}".ToUpper();
        return name.Length > 0 ? name.Substring(0, Math.Min(2, name.Length)).ToUpper() : "?";
    }

    private string GetTimeAgo(DateTime date)
    {
        var diff = DateTime.Now - date;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d ago";
        return date.ToString("MMM dd, yyyy");
    }


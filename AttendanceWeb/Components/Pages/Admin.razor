    private async Task ExportRecordsToExcel()
    {
        if (!eventRecords.Any()) return;
        
        var exportData = eventRecords.Select(r => new {
            StudentId = r.Student.StudentId,
            Name = r.Student.Name,
            Year = r.Student.YearLevel,
            Section = r.Student.Section ?? "-",
            Event = r.Event.EventName,
            TimeIn = r.Record.TimeIn?.ToString("hh:mm tt") ?? "-",
            TimeOut = r.Record.TimeOut?.ToString("hh:mm tt") ?? "-",
            Status = (r.Record.TimeIn != null && r.Record.TimeOut != null ? "Complete" : r.Record.TimeIn != null ? "Time In Only" : "No Record"),
            Date = r.Record.RecordDate.ToString("yyyy-MM-dd")
        }).ToList();
        
        await JSRuntime.InvokeVoidAsync("exportToExcel", exportData, $"AttendanceRecords_{DateTime.Now:yyyyMMdd_HHmm}.xlsx");
        Database.LogActivity(AuthService.AdminId, AuthService.AdminUsername, "Export", "Records", "Exported attendance records to Excel.");
    }

    private async Task ExportRecordsToPDF()
    {
        if (!eventRecords.Any()) return;

        var title = selectedEventId == 0 ? "All Attendance Records" : $"Attendance: {eventRecords.FirstOrDefault()?.Event.EventName ?? "Records"}";
        var headers = new string[] { "Student ID", "Name", "Year/Sec", "Time In", "Time Out", "Status", "Date" };
        var data = eventRecords.Select(r => new string[] {
            r.Student.StudentId,
            r.Student.Name,
            $"{r.Student.YearLevel}{r.Student.Section}",
            r.Record.TimeIn?.ToString("hh:mm tt") ?? "-",
            r.Record.TimeOut?.ToString("hh:mm tt") ?? "-",
            (r.Record.TimeIn != null && r.Record.TimeOut != null ? "Complete" : r.Record.TimeIn != null ? "Time In Only" : "No Record"),
            r.Record.RecordDate.ToString("MMM dd, yyyy")
        }).ToArray();
        
        await JSRuntime.InvokeVoidAsync("exportToPDF", title, headers, data, $"Attendance_{DateTime.Now:yyyyMMdd_HHmm}.pdf");
        Database.LogActivity(AuthService.AdminId, AuthService.AdminUsername, "Export", "Records", "Exported attendance records to PDF.");
    }




@page "/admin/login"
@using AttendanceWeb.Models
@using AttendanceWeb.Services
@inject AttendanceDatabase Database
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Admin Login</PageTitle>

<div class="login-container">
    <button class="btn-fullscreen-login" @onclick="ToggleFullscreen" title="@(isFullscreen ? "Exit Fullscreen" : "Enter Fullscreen")">
        @(isFullscreen ? "🗗" : "⛶")
    </button>
    
    <div class="login-card">
        <div class="login-header">
            <h1>🔐 Admin Login</h1>
            <p>Enter your credentials</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">⚠️ @errorMessage</div>
        }

        <div class="form-group">
            <label>Username</label>
            <input class="form-control" @bind="username" placeholder="Enter username" />
        </div>
        
        <div class="form-group">
            <label>Password</label>
            <div class="password-wrapper">
                <input type="@(showLoginPassword ? "text" : "password")" class="form-control" @bind="password" placeholder="Enter password" @onkeypress="HandleKeyPress" />
                <button type="button" class="btn-toggle-pw" @onclick="() => showLoginPassword = !showLoginPassword" tabindex="-1">
                    @(showLoginPassword ? "🙈" : "👁️")
                </button>
            </div>
        </div>

        <button class="btn btn-primary btn-block" @onclick="LoginWithPassword" disabled="@isLoading">
            @(isLoading ? "Logging in..." : "Login")
        </button>

        <div style="text-align: center; margin-top: 1rem;">
            <button class="btn-link" @onclick="ShowForgotPassword" style="background: none; border: none; color: #667eea; cursor: pointer; font-size: 0.9rem; text-decoration: underline;">
                Forgot Password?
            </button>
        </div>
    </div>

    @if (showForgotPassword)
    {
        <div class="login-card" style="margin-top: 1rem;">
            <div class="login-header">
                <h2 style="font-size: 1.3rem;">🔑 Reset Password</h2>
                <p style="font-size: 0.85rem;">Answer your security question to reset your password</p>
            </div>

            @if (!string.IsNullOrEmpty(resetMessage))
            {
                <div class="alert @(resetSuccess ? "alert-success" : "alert-error")">@(resetSuccess ? "✅" : "⚠️") @resetMessage</div>
            }

            @if (resetStep == 1)
            {
                <div class="form-group">
                    <label>Username (from login form)</label>
                    <input class="form-control" @bind="username" placeholder="Enter username" />
                </div>
                <button class="btn btn-primary btn-block" @onclick="FindAdminForReset">Next</button>
            }
            else if (resetStep == 2)
            {
                <div class="form-group">
                    <label>Security Question</label>
                    <p style="font-weight: 600; color: #2d3748; padding: 0.5rem; background: #f7fafc; border-radius: 8px;">@resetSecurityQuestion</p>
                </div>
                <div class="form-group">
                    <label>Your Answer</label>
                    <input class="form-control" @bind="resetSecurityAnswer" placeholder="Enter your answer" />
                </div>
                <button class="btn btn-primary btn-block" @onclick="VerifySecurityAnswer">Verify</button>
            }
            else if (resetStep == 3)
            {
                <div class="form-group">
                    <label>New Password</label>
                    <div class="password-wrapper">
                        <input type="@(showResetPw ? "text" : "password")" class="form-control" @bind="resetNewPassword" placeholder="Enter new password" />
                        <button type="button" class="btn-toggle-pw" @onclick="() => showResetPw = !showResetPw" tabindex="-1">@(showResetPw ? "🙈" : "👁️")</button>
                    </div>
                </div>
                <div class="form-group">
                    <label>Confirm New Password</label>
                    <div class="password-wrapper">
                        <input type="@(showResetConfirmPw ? "text" : "password")" class="form-control" @bind="resetConfirmPassword" placeholder="Confirm new password" />
                        <button type="button" class="btn-toggle-pw" @onclick="() => showResetConfirmPw = !showResetConfirmPw" tabindex="-1">@(showResetConfirmPw ? "🙈" : "👁️")</button>
                    </div>
                </div>
                <button class="btn btn-primary btn-block" @onclick="ResetPasswordConfirm">Reset Password</button>
            }

            <button class="btn-link" @onclick="CancelForgotPassword" style="display: block; margin: 1rem auto 0; background: none; border: none; color: #718096; cursor: pointer; font-size: 0.85rem;">
                ← Back to Login
            </button>
        </div>
    }
</div>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    .login-card {
        background: white;
        padding: 2rem;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        width: 100%;
        max-width: 400px;
    }
    
    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .login-header h1 {
        color: #2d3748;
        font-size: 1.8rem;
        margin-bottom: 0.5rem;
    }
    
    .form-group {
        margin-bottom: 1.5rem;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        color: #4a5568;
        font-weight: 500;
    }
    
    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.2s;
    }
    
    .form-control:focus {
        border-color: #667eea;
        outline: none;
    }
    
    .btn-block {
        width: 100%;
        padding: 1rem;
        font-size: 1.1rem;
        margin-top: 1rem;
    }

    .alert {
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }
    
    .alert-error {
        background-color: #fff5f5;
        color: #c53030;
        border: 1px solid #feb2b2;
    }

    .btn-fullscreen-login {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 10px;
        width: 44px;
        height: 44px;
        border-radius: 10px;
        cursor: pointer;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        backdrop-filter: blur(5px);
        z-index: 10;
    }

    .btn-fullscreen-login:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.05);
    }

    .password-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .password-wrapper .form-control {
        padding-right: 44px;
    }

    .btn-toggle-pw {
        position: absolute;
        right: 8px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1.1rem;
        padding: 4px;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .btn-toggle-pw:hover {
        opacity: 1;
    }

    .alert-success {
        background-color: #f0fff4;
        color: #276749;
        border: 1px solid #9ae6b4;
    }
</style>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool isFullscreen = false;
    private bool showLoginPassword = false;

    // Forgot password state
    private bool showForgotPassword = false;
    private int resetStep = 1;
    private string resetUsername = "";
    private string resetSecurityQuestion = "";
    private string resetSecurityAnswer = "";
    private string resetNewPassword = "";
    private string resetConfirmPassword = "";
    private string resetMessage = "";
    private bool resetSuccess = false;
    private bool showResetPw = false;
    private bool showResetConfirmPw = false;
    private int resetAdminId = 0;

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoginWithPassword();
        }
    }

    private async Task LoginWithPassword()
    {
        isLoading = true;
        errorMessage = "";
        
        try
        {
            var admins = await Database.GetAllAdminsAsync();
            var admin = admins.FirstOrDefault(a => a.Username.Equals(username, StringComparison.OrdinalIgnoreCase));
            
            if (admin != null)
            {
                if (admin.Password == password)
                {
                    Database.UpdateLastLogin(admin.Id);
                    Database.LogActivity(admin.Id, admin.Username, "Login", "Admin", "Password login successful.");
                    AuthService.Login(admin.Username, admin.Id);
                    
                    // Persist session via localStorage
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "adminUser", admin.Username);
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "adminId", admin.Id.ToString());
                    
                    Navigation.NavigateTo("/admin/dashboard");
                }
                else
                {
                    errorMessage = "Invalid password.";
                }
            }
            else
            {
                // Fallback for initial setup if empty or default admin
                if (admins.Count == 0 && username == "admin" && password == "admin")
                {
                    Database.LogActivity(0, "admin", "Login", "Admin", "Default admin login successful.");
                    AuthService.Login("admin", 0);
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "adminUser", "admin");
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "adminId", "0");
                    Navigation.NavigateTo("/admin/dashboard");
                }
                else
                {
                    errorMessage = "Invalid username or password.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Login error: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedUser = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "adminUser");
            var savedIdStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "adminId");
            if (!string.IsNullOrEmpty(savedUser))
            {
                int adminId = 0;
                int.TryParse(savedIdStr, out adminId);
                AuthService.Login(savedUser, adminId);
                Navigation.NavigateTo("/admin/dashboard");
            }
        }
    }

    private void ShowForgotPassword()
    {
        showForgotPassword = true;
        resetStep = 1;
        resetUsername = "";
        resetMessage = "";
        resetSuccess = false;
        errorMessage = "";
    }

    private void CancelForgotPassword()
    {
        showForgotPassword = false;
        resetStep = 1;
        resetUsername = "";
        resetSecurityQuestion = "";
        resetSecurityAnswer = "";
        resetNewPassword = "";
        resetConfirmPassword = "";
        resetMessage = "";
        resetSuccess = false;
        resetAdminId = 0;
    }

    private async Task FindAdminForReset()
    {
        resetMessage = "";
        if (string.IsNullOrWhiteSpace(username))
        {
            resetMessage = "Enter your username in the login form first.";
            return;
        }

        resetUsername = username.Trim();

        var admins = await Database.GetAllAdminsAsync();
        var admin = admins.FirstOrDefault(a => a.Username.Equals(resetUsername, StringComparison.OrdinalIgnoreCase));

        if (admin == null)
        {
            resetMessage = "Username not found.";
            return;
        }

        if (string.IsNullOrWhiteSpace(admin.SecurityQuestion) || string.IsNullOrWhiteSpace(admin.SecurityAnswer))
        {
            resetMessage = "No security question set for this account. Contact another admin to reset your password.";
            return;
        }

        resetAdminId = admin.Id;
        resetSecurityQuestion = admin.SecurityQuestion;
        resetStep = 2;
    }

    private async Task VerifySecurityAnswer()
    {
        resetMessage = "";
        if (string.IsNullOrWhiteSpace(resetSecurityAnswer))
        {
            resetMessage = "Please enter your answer.";
            return;
        }

        var admin = await Task.Run(() => Database.GetAdminById(resetAdminId));
        if (admin == null)
        {
            resetMessage = "Admin not found.";
            return;
        }

        if (!admin.SecurityAnswer.Equals(resetSecurityAnswer, StringComparison.OrdinalIgnoreCase))
        {
            resetMessage = "Incorrect answer. Please try again.";
            return;
        }

        resetStep = 3;
        resetMessage = "";
    }

    private async Task ResetPasswordConfirm()
    {
        resetMessage = "";
        resetSuccess = false;

        if (string.IsNullOrWhiteSpace(resetNewPassword))
        {
            resetMessage = "Please enter a new password.";
            return;
        }

        if (resetNewPassword != resetConfirmPassword)
        {
            resetMessage = "Passwords do not match.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(resetNewPassword, @"^(?=.*[a-zA-Z])(?=.*\d)(?=.*[\W_]).{4,}$"))
        {
            resetMessage = "Password must contain letters, numbers, and special characters.";
            return;
        }

        try
        {
            var admin = await Task.Run(() => Database.GetAdminById(resetAdminId));
            if (admin == null)
            {
                resetMessage = "Admin not found.";
                return;
            }

            admin.Password = resetNewPassword;
            await Task.Run(() => Database.UpdateAdmin(admin));

            resetMessage = "Password reset successfully! You can now log in.";
            resetSuccess = true;

            await Task.Delay(2000);
            CancelForgotPassword();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            resetMessage = "Error resetting password: " + ex.Message;
        }
    }

    private async Task ToggleFullscreen()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("toggleFullscreen");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fullscreen error: {ex.Message}");
            errorMessage = "Fullscreen not supported. Press F11 key to enter fullscreen.";
            StateHasChanged();
            await Task.Delay(3000);
            errorMessage = "";
            StateHasChanged();
        }
    }
}